rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection: each user can read/write only their own document
    // The backend (Firebase Admin SDK) bypasses these rules entirely
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Ratings: authenticated users can read all, write only their own
    match /ratings/{ratingId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Reviews: authenticated users can read all, write only their own
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }
  }
}
